# Schwab OAuth configuration
SCHWAB_CLIENT_ID=your_client_id_here
SCHWAB_CLIENT_SECRET=your_client_secret_here
SCHWAB_REDIRECT_URI=https://127.0.0.1
SCHWAB_SCOPE=readonly
CHART_TUI_SCHWAB_TOKEN_FILE=
CHART_TUI_SCHWAB_MODE=live
CHART_TUI_SCHWAB_AUTO_REFRESH=1

# Data provider: synthetic or schwab
CHART_TUI_PROVIDER=schwab
